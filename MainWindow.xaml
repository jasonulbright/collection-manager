<Controls:MetroWindow
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    Title="Collection Manager"
    Width="1320" Height="820"
    MinWidth="1024" MinHeight="640"
    WindowStartupLocation="CenterScreen"
    TitleCharacterCasing="Normal"
    GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    NonActiveGlowBrush="{DynamicResource MahApps.Brushes.Accent}"
    BorderThickness="1"
    ShowIconOnTitleBar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Themes/Dark.Steel.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <ControlTemplate x:Key="SidebarButtonTemplate" TargetType="Button">
                <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        SnapsToDevicePixels="True">
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Margin="{TemplateBinding Padding}"
                                      RecognizesAccessKey="True"
                                      SnapsToDevicePixels="True"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Bd" Property="Background">
                            <Setter.Value>
                                <SolidColorBrush Color="#3A3A3A"/>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <Style x:Key="ViewButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="Margin" Value="8,3,8,3"/>
                <Setter Property="Padding" Value="12,0,12,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Controls:ControlsHelper.ContentCharacterCasing" Value="Normal"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background">
                    <Setter.Value><SolidColorBrush Color="#1E1E1E"/></Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value><SolidColorBrush Color="#555555"/></Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="OptionsButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                <Setter Property="Template" Value="{StaticResource SidebarButtonTemplate}"/>
                <Setter Property="Height" Value="42"/>
                <Setter Property="Margin" Value="8,3,8,3"/>
                <Setter Property="Padding" Value="12,0,12,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Controls:ControlsHelper.ContentCharacterCasing" Value="Normal"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background">
                    <Setter.Value><SolidColorBrush Color="#1E1E1E"/></Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value><SolidColorBrush Color="#555555"/></Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="SquareInlineButtonStyle" TargetType="Button" BasedOn="{StaticResource MahApps.Styles.Button.Square}">
                <Setter Property="Height" Value="28"/>
                <Setter Property="MinWidth" Value="100"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
                <Setter Property="Controls:ControlsHelper.ContentCharacterCasing" Value="Normal"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <!-- Row style owns alternating + IsSelected backgrounds. Setting
                 RowBackground/AlternatingRowBackground on the DataGrid binds
                 those as LOCAL values, which beat Style triggers in WPF's
                 dependency-property precedence chain. Mouse-click selection
                 IS happening (keyboard arrow proves it) but the highlight
                 never rendered with the per-DataGrid setters in play. -->
            <Style x:Key="ViewDataGridRow" TargetType="DataGridRow"
                   BasedOn="{StaticResource MahApps.Styles.DataGridRow}">
                <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}"/>
                <Style.Triggers>
                    <Trigger Property="AlternationIndex" Value="1">
                        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Control.Background}"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                        <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.IdealForeground}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ViewDataGrid" TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="ColumnHeaderHeight" Value="30"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Background" Value="{DynamicResource MahApps.Brushes.ThemeBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource MahApps.Brushes.Gray8}"/>
                <Setter Property="AlternationCount" Value="2"/>
                <Setter Property="RowStyle" Value="{StaticResource ViewDataGridRow}"/>
            </Style>

            <Style x:Key="GridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource MahApps.Styles.DataGridCell}">
                <Setter Property="Padding" Value="6,0,6,0"/>
            </Style>

            <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MahApps.Styles.DataGridColumnHeader}">
                <Setter Property="Padding" Value="6,0,6,0"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style x:Key="DetailTextStyle" TargetType="TextBox">
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="8"/>
            </Style>

            <Style x:Key="WqlEditorStyle" TargetType="TextBox">
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="FontFamily" Value="Cascadia Code, Consolas, Courier New"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Padding" Value="8"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================================================================ -->
        <!-- LEFT SIDEBAR                                                     -->
        <!-- ================================================================ -->
        <Border Grid.Column="0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="14,14,14,12">
                    <TextBlock x:Name="txtAppTitle" Text="Collection Manager"
                               FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="txtVersion" Text="v1.0.1" FontSize="10"
                               Foreground="{DynamicResource MahApps.Brushes.Gray1}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,14">
                    <Separator Margin="0,8,0,10"/>
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="txtThemeLabel" Text="Dark Theme"
                                   DockPanel.Dock="Left" VerticalAlignment="Center" FontSize="12"/>
                        <Controls:ToggleSwitch x:Name="toggleTheme"
                                               DockPanel.Dock="Right"
                                               IsOn="True"
                                               OnContent="" OffContent=""
                                               MinWidth="0"
                                               ToolTip="Toggle dark / light theme"/>
                    </DockPanel>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Button x:Name="btnViewCollections" Content="Collections" Style="{StaticResource ViewButtonStyle}"
                                ToolTip="Browse all device collections, edit membership, create / copy / remove"/>
                        <Button x:Name="btnViewWqlEditor"  Content="WQL Editor"  Style="{StaticResource ViewButtonStyle}"
                                ToolTip="Offline WQL editor for collection query rules with validation and preview"/>
                        <Button x:Name="btnViewTemplates"  Content="Templates"   Style="{StaticResource ViewButtonStyle}"
                                ToolTip="Ready-made and parameterized query templates"/>

                        <Button x:Name="btnOptions" Content="Options"
                                Style="{StaticResource OptionsButtonStyle}"
                                Margin="8,24,8,3"
                                ToolTip="Site code, SMS provider, about"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Background="{DynamicResource MahApps.Brushes.Gray8}"/>

        <!-- ================================================================ -->
        <!-- MAIN CONTENT AREA                                                -->
        <!-- ================================================================ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="160"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource MahApps.Brushes.Gray10}" Padding="16,12,16,10">
                <StackPanel>
                    <TextBlock x:Name="txtModuleTitle" Text="Collections" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock x:Name="txtModuleSubtitle"
                               Text="Configure Site / Provider in Options, then click Refresh."
                               FontSize="11"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MahApps.Brushes.Gray1}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Padding="16,10,16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnRefresh"
                            Grid.Column="0"
                            Content="Refresh"
                            Style="{StaticResource SquareInlineButtonStyle}"
                            MinWidth="120"
                            ToolTip="Reload from MECM (or, on the Templates view, reload templates from disk)"/>

                    <TextBox x:Name="txtFilter"
                             Grid.Column="1"
                             FontSize="12"
                             Padding="6,4,6,4"
                             Margin="8,0,8,0"
                             Controls:TextBoxHelper.Watermark="Filter by name..."/>

                    <ComboBox x:Name="cboCollectionFilter"
                              Grid.Column="2"
                              Width="180"
                              Margin="0,0,8,0"
                              FontSize="12"
                              ToolTip="Limit rows by membership shape">
                        <ComboBoxItem Content="All" IsSelected="True"/>
                        <ComboBoxItem Content="Built-in only"/>
                        <ComboBoxItem Content="Custom only"/>
                        <ComboBoxItem Content="Empty (zero members)"/>
                        <ComboBoxItem Content="Has direct members"/>
                        <ComboBoxItem Content="Has query rules"/>
                    </ComboBox>

                    <Button x:Name="btnExportCsv"  Grid.Column="3" Content="Export CSV"  Style="{StaticResource SquareInlineButtonStyle}"
                            ToolTip="Export the active view to CSV"/>
                    <Button x:Name="btnExportHtml" Grid.Column="4" Content="Export HTML" Style="{StaticResource SquareInlineButtonStyle}"
                            ToolTip="Export the active view to a styled HTML report"/>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Margin="8,0,8,0">

                <!-- ============================================================ -->
                <!-- View: Collections                                            -->
                <!-- ============================================================ -->
                <Grid x:Name="viewCollections" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="5"/>
                        <RowDefinition Height="260"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="gridCollections"
                              Grid.Row="0"
                              Style="{StaticResource ViewDataGrid}"
                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                              CellStyle="{StaticResource GridCellStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="" Width="32"
                                                Binding="{Binding TypeGlyph}"/>
                            <DataGridTextColumn Header="Name" Width="2*"
                                                Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="ID" Width="100"
                                                Binding="{Binding CollectionID}"/>
                            <DataGridTextColumn Header="Members" Width="80"
                                                Binding="{Binding MemberCount}"/>
                            <DataGridTextColumn Header="Limiting Collection" Width="2*"
                                                Binding="{Binding LimitingCollection}"/>
                            <DataGridTextColumn Header="Refresh" Width="100"
                                                Binding="{Binding RefreshType}"/>
                            <DataGridTextColumn Header="Comment" Width="*"
                                                Binding="{Binding Comment}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource MahApps.Brushes.Gray8}"
                                  ResizeDirection="Rows"/>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="0,8,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnNewCollection"  Content="New Collection"   Style="{StaticResource SquareInlineButtonStyle}" MinWidth="130"
                                        ToolTip="Create a new device collection"/>
                                <Button x:Name="btnCopyCollection" Content="Copy..."          Style="{StaticResource SquareInlineButtonStyle}" MinWidth="100"
                                        ToolTip="Clone the selected collection (rules + name + comment)"/>
                                <Button x:Name="btnEditMembership" Content="Edit Membership..." Style="{StaticResource SquareInlineButtonStyle}" MinWidth="150"
                                        ToolTip="Add / remove direct members, include / exclude rules"/>
                                <Button x:Name="btnEvaluateColl"   Content="Evaluate"         Style="{StaticResource SquareInlineButtonStyle}" MinWidth="100"
                                        ToolTip="Force a membership evaluation on the selected collection"/>
                                <Button x:Name="btnRemoveColl"     Content="Remove..."        Style="{StaticResource SquareInlineButtonStyle}" MinWidth="100"
                                        ToolTip="Delete the selected collection"/>
                            </StackPanel>
                        </Border>

                        <TabControl x:Name="tabCollDetail" Grid.Row="1"
                                    BorderThickness="0"
                                    Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
                            <TabItem Header="Properties">
                                <TextBox x:Name="txtCollProperties"
                                         Style="{StaticResource DetailTextStyle}"
                                         Text="Select a collection to see its properties."/>
                            </TabItem>
                            <TabItem Header="Direct Members">
                                <DataGrid x:Name="gridDirectMembers"
                                          Style="{StaticResource ViewDataGrid}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          CellStyle="{StaticResource GridCellStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Resource Name" Width="2*" Binding="{Binding Name}"/>
                                        <DataGridTextColumn Header="Resource ID"   Width="120" Binding="{Binding ResourceID}"/>
                                        <DataGridTextColumn Header="Domain"        Width="*"   Binding="{Binding Domain}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Query Rules">
                                <DataGrid x:Name="gridQueryRules"
                                          Style="{StaticResource ViewDataGrid}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          CellStyle="{StaticResource GridCellStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Rule Name" Width="*"   Binding="{Binding RuleName}"/>
                                        <DataGridTextColumn Header="WQL"       Width="3*"  Binding="{Binding QueryExpression}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Include Rules">
                                <DataGrid x:Name="gridIncludeRules"
                                          Style="{StaticResource ViewDataGrid}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          CellStyle="{StaticResource GridCellStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Included Collection" Width="*"   Binding="{Binding IncludeCollectionName}"/>
                                        <DataGridTextColumn Header="ID"                  Width="120" Binding="{Binding IncludeCollectionID}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Exclude Rules">
                                <DataGrid x:Name="gridExcludeRules"
                                          Style="{StaticResource ViewDataGrid}"
                                          ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                          CellStyle="{StaticResource GridCellStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Excluded Collection" Width="*"   Binding="{Binding ExcludeCollectionName}"/>
                                        <DataGridTextColumn Header="ID"                  Width="120" Binding="{Binding ExcludeCollectionID}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Grid>

                <!-- ============================================================ -->
                <!-- View: WQL Editor                                             -->
                <!-- ============================================================ -->
                <Grid x:Name="viewWqlEditor" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380" MinWidth="280"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: full-height collection tree (folder hierarchy) -->
                    <DockPanel Grid.Column="0" Margin="0,0,0,0">
                        <TextBox x:Name="txtWqlTreeFilter" DockPanel.Dock="Top" FontSize="12" Padding="6,4,6,4" Margin="0,8,0,8"
                                 Controls:TextBoxHelper.Watermark="Filter collections by name or ID..."/>
                        <Border BorderThickness="1"
                                BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                                Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
                            <TreeView x:Name="treeWqlCollections" FontSize="12" BorderThickness="0"
                                      Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                      Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling"/>
                        </Border>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource MahApps.Brushes.Gray8}"
                                  ResizeDirection="Columns"/>

                    <!-- RIGHT: rules-in-collection list, rule editor, action buttons -->
                    <Grid Grid.Column="2" Margin="8,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="160"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="txtSelectedColl" Grid.Row="0" FontSize="12" Margin="0,8,0,8"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray1}"
                                   Text="Pick a collection from the tree on the left."
                                   TextTrimming="CharacterEllipsis"/>

                        <TextBlock Grid.Row="1" Text="Rules in this collection" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        <Border Grid.Row="2" BorderThickness="1"
                                BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"
                                Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
                            <ListBox x:Name="lstWqlRules" FontSize="12" BorderThickness="0"
                                     Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                     Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"/>
                        </Border>

                        <TextBlock Grid.Row="3" Text="Rule Name" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,4"/>
                        <TextBox x:Name="txtRuleName" Grid.Row="4" FontSize="12" Padding="6,4,6,4" Margin="0,0,0,8"/>

                        <TextBox x:Name="txtWqlEditor" Grid.Row="5" Style="{StaticResource WqlEditorStyle}"
                                 Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                 Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                 BorderThickness="1"
                                 BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"/>

                        <Border Grid.Row="6" Padding="0,8,0,8">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnValidateWql" Content="Validate Query"  Style="{StaticResource SquareInlineButtonStyle}" MinWidth="130"
                                        ToolTip="Run a syntax check on the WQL editor contents"/>
                                <Button x:Name="btnPreviewWql"  Content="Preview Results" Style="{StaticResource SquareInlineButtonStyle}" MinWidth="130"
                                        ToolTip="Run the WQL against the SMS Provider and show match count + sample"/>
                                <Button x:Name="btnAddRule"    Content="Add Rule"    Style="{StaticResource SquareInlineButtonStyle}" MinWidth="100"
                                        ToolTip="Add the editor contents as a new query rule"/>
                                <Button x:Name="btnUpdateRule" Content="Update Rule" Style="{StaticResource SquareInlineButtonStyle}" MinWidth="110"
                                        ToolTip="Replace the selected rule's WQL with the editor contents"/>
                                <Button x:Name="btnRemoveRule" Content="Remove..."   Style="{StaticResource SquareInlineButtonStyle}" MinWidth="100"
                                        ToolTip="Delete the selected query rule"/>
                                <TextBlock x:Name="txtWqlValidation" FontSize="12"
                                           VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{DynamicResource MahApps.Brushes.Gray1}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ============================================================ -->
                <!-- View: Templates                                              -->
                <!-- ============================================================ -->
                <Grid x:Name="viewTemplates" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <TabControl x:Name="tabTemplateKind" Grid.Column="0"
                                BorderThickness="0"
                                Background="{DynamicResource MahApps.Brushes.ThemeBackground}">
                        <TabItem Header="Operational">
                            <DataGrid x:Name="gridOperationalTemplates"
                                      Style="{StaticResource ViewDataGrid}"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      CellStyle="{StaticResource GridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Width="120" Binding="{Binding Category}"/>
                                    <DataGridTextColumn Header="Name"     Width="*"   Binding="{Binding Name}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                        <TabItem Header="Parameterized">
                            <DataGrid x:Name="gridParameterizedTemplates"
                                      Style="{StaticResource ViewDataGrid}"
                                      ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                                      CellStyle="{StaticResource GridCellStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Category" Width="120" Binding="{Binding Category}"/>
                                    <DataGridTextColumn Header="Name"     Width="*"   Binding="{Binding Name}"/>
                                    <DataGridTextColumn Header="Params"   Width="60"  Binding="{Binding ParameterCount}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </TabItem>
                    </TabControl>

                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource MahApps.Brushes.Gray8}"
                                  ResizeDirection="Columns"/>

                    <DockPanel Grid.Column="2" Margin="8,0,0,0">
                        <Border DockPanel.Dock="Bottom" Padding="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="btnCopyToWqlEditor" Content="Copy to WQL Editor"      Style="{StaticResource SquareInlineButtonStyle}" MinWidth="160"
                                        ToolTip="Send the expanded query to the WQL Editor view"/>
                                <Button x:Name="btnApplyTemplate"   Content="Apply to Collection..."  Style="{StaticResource SquareInlineButtonStyle}" MinWidth="170"
                                        ToolTip="Add the expanded query as a rule on a chosen collection"/>
                            </StackPanel>
                        </Border>

                        <StackPanel DockPanel.Dock="Top">
                            <TextBlock Text="Description" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <TextBlock x:Name="txtTemplateDescription" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray1}"/>

                            <TextBlock Text="Limiting Collection" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,4"/>
                            <TextBlock x:Name="txtTemplateLimiting" FontSize="12"
                                       Foreground="{DynamicResource MahApps.Brushes.Gray1}"/>

                            <TextBlock x:Name="txtTemplateParamsHeader" Text="Parameters" FontSize="11" FontWeight="SemiBold" Margin="0,12,0,4" Visibility="Collapsed"/>
                            <ItemsControl x:Name="itemsTemplateParams" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,2,0,2" LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Left" Text="{Binding Label}" FontSize="11" Width="140" VerticalAlignment="Center"/>
                                            <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="6,4,6,4"
                                                     ToolTip="{Binding HelpText}"/>
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Expanded WQL" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,4"/>
                        </StackPanel>

                        <TextBox x:Name="txtTemplateExpandedQuery"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="12"
                                 Padding="8"
                                 Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                                 Foreground="{DynamicResource MahApps.Brushes.ThemeForeground}"
                                 BorderThickness="1"
                                 BorderBrush="{DynamicResource MahApps.Brushes.Gray8}"/>
                    </DockPanel>
                </Grid>

                <!-- ============================================================ -->
                <!-- Progress overlay (refresh in flight)                         -->
                <!-- ============================================================ -->
                <Border x:Name="progressOverlay"
                        Visibility="Collapsed"
                        IsHitTestVisible="False"
                        Background="{DynamicResource MahApps.Brushes.ThemeBackground}"
                        Opacity="0.92">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Controls:ProgressRing IsActive="True" Width="56" Height="56"
                                               Foreground="{DynamicResource MahApps.Brushes.Accent}"/>
                        <TextBlock x:Name="txtProgressTitle"
                                   Text="Loading..."
                                   FontSize="18" FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   Margin="0,14,0,0"/>
                        <TextBlock x:Name="txtProgressStep"
                                   Text=""
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource MahApps.Brushes.Gray1}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource MahApps.Brushes.Gray8}"
                          ResizeDirection="Rows"/>

            <Border Grid.Row="4">
                <DockPanel>
                    <TextBlock x:Name="lblLogOutput" DockPanel.Dock="Top" Text="LOG OUTPUT"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="8,6,0,4"/>
                    <TextBox x:Name="txtLog"
                             IsReadOnly="True"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="11"
                             BorderThickness="0"
                             Margin="4,0,4,4"/>
                </DockPanel>
            </Border>

            <Border Grid.Row="5" Padding="8,4,8,4"
                    Background="{DynamicResource MahApps.Brushes.Gray10}">
                <TextBlock x:Name="txtStatus" Text="Ready." FontSize="11"/>
            </Border>
        </Grid>
    </Grid>

</Controls:MetroWindow>
